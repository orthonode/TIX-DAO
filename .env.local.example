# Solana network — 'devnet' for development, 'mainnet-beta' for production
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Official SPL-Governance program address (same on devnet and mainnet)
NEXT_PUBLIC_GOVERNANCE_PROGRAM_ID=GovER5Lthms3bLBqWub97yVrMmEogzX7xNjdXpPPCVZw

# ve$TICK escrow program (replace with your deployed program ID)
NEXT_PUBLIC_TICK_ESCROW_PROGRAM_ID=YOUR_ESCROW_PROGRAM_ID_HERE

# Optional: override the default public RPC with a private endpoint
# Get a free key at helius.dev — strongly recommended for production
# NEXT_PUBLIC_RPC_ENDPOINT=https://devnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
